{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "uvnvpy",
  "version": "0.1.0",
  "identifier": "de.serestou.uvnvpy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "uvnvpy",
        "width": 1280,
        "height": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/logo.png"
    ]
  }
}
