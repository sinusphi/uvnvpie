{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "uvnvpy",
  "version": "0.1.0",
  "identifier": "de.serestou.uvnvpy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "uvnvpy",
        "width": 1200,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 720,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/logo.png"
    ]
  }
}
