{
  "$schema": "../.vscode/tauri-config-schema.json",
  "productName": "uvnvpie",
  "version": "0.1.1",
  "identifier": "de.serestou.uvnvpie",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "uvnvpie",
        "width": 1280,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capability for the main window",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "core:window:default",
            "core:window:allow-start-dragging",
            "core:window:allow-minimize",
            "core:window:allow-toggle-maximize",
            "core:window:allow-close",
            "store:default",
            "dialog:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/logo.png"
    ]
  }
}
